# ── Agent-Hub 环境变量配置 ──────────────────────────────
# 复制此文件为 .env 并填入真实值。
# 切勿将 .env 提交到版本控制。

# ── LLM（OpenAI 兼容接口） ───────────────────────────────
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4.5-air

# ── 本地 API / Dashboard ───────────────────────────────
PUBLIC_BASE_URL=http://127.0.0.1:8080
DASHBOARD_STATIC_DIR=web
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://localhost:3000

# ── Pilot 开关 ─────────────────────────────────────────
PILOT_ENABLED=true
PILOT_STORE_PATH=./data/pilot.sqlite3
PILOT_DEMO_MODE=true
PILOT_AUTO_APPROVE_WRITES=true
PILOT_USE_REAL_GATEWAY=false
PILOT_USE_REAL_CHAIN=false
PILOT_PROGRESS_HEARTBEAT_INTERVAL_SECONDS=5
PILOT_ARTIFACT_DIR=data/pilot/artifacts
PILOT_ADMIN_TOKEN=change-me

# ── 飞书机器人（飞书开放平台 → 自建应用获取） ─────────────
FEISHU_ENABLED=true
FEISHU_USE_LONG_CONN=true
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_APP_TYPE=self_built
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=
FEISHU_BOT_OPEN_ID=ou_xxx
FEISHU_REQUIRE_MENTION_IN_GROUP=true
FEISHU_TRIGGER_KEYWORDS=
FEISHU_DEFAULT_FOLDER_TOKEN=
FEISHU_ADMIN_OPEN_ID=
FEISHU_PROGRESS_MIN_INTERVAL_SECONDS=5

# ── 内核与依赖 ─────────────────────────────────────────
OBSIDIAN_VAULT_PATH=./data/obsidian
RAG_API_BASE=http://localhost:8000
PG_DSN=postgresql://localhost:5432/agent_hub
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=false
VECTOR_MEMORY_ENABLED=false
RATE_LIMITER_ENABLED=false
GUARD_ENABLED=true
GUARD_LLM_ENABLED=true

# ── 日志 ──────────────────────────────────────────────
LOG_LEVEL=INFO
